PORT=3001
NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Clerk keys (required for auth)
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key
CLERK_WEBHOOK_SECRET=whsec_your_clerk_webhook_secret

# Frontend URL used for return URLs and support links
FRONTEND_URL=http://localhost:5173

# Stream/Chat keys (required if you use chat/video features)
STREAM_API_KEY=your_stream_api_key
STREAM_API_SECRET=your_stream_api_secret

# ImageKit (optional if image uploads are used)
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your-endpoint

# Sentry (optional)
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Polar API
POLAR_ACCESS_TOKEN=your_polar_access_token
POLAR_WEBHOOK_SECRET=your_polar_webhook_secret
POLAR_API_BASE=https://sandbox-api.polar.sh
POLAR_CHECKOUT_PRODUCT_ID=00000000-0000-0000-0000-000000000000

